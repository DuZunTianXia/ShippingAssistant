{
  "name": "shipping-assistant",
  "version": "1.0.0",
  "description": "闲鱼发货助手 - 自定义字段管理系统",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "node server/index.js",
    "dev:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "deploy": "npm run build:frontend && wrangler deploy",
    "db:migrate": "wrangler d1 execute shipping-db --local --file=./schema.sql",
    "db:migrate:prod": "wrangler d1 execute shipping-db --file=./schema.sql"
  },
  "keywords": ["shipping", "cloudflare", "vue3", "express"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
